<form method="POST" action="/settings/<%=username%>">
    <label for="password">Password:</label>
    <input type="password" name="password" id="password" required pattern="<%=passwordRegex%>">

    <br> <br>

    <label for="randomness">Use randomness:</label>
    <small>If true then the images will render randomly. Or it will be in sequential oder.</small>
    <select name="randomness" id="randomness">
        <option value="true">True</option>
        <option value="false">False</option>
    </select>

    <br><br>

    <label for="ttl">Refresh Frequency:</label>
    <small> How often you want your image/url to be refreshed.</small>
    <select name="ttl" id="ttl">
        <option value="0">Every request</option>
        <option value="60">Every min</option>
        <option value="3600">Every hour</option>
        <option value="86400">Every day</option>
        <option value="604800">Every week</option>
        <option value="2630000">Every Month</option>
    </select>
    <br><br>

    <label for="periodicity">Guarantee Periodicity:</label>
    <small> Ensuring that image/url change on selected frequency. More in FAQ</small>
    <select name="periodicity" id="periodicity" disabled>
        <option value="true">True</option>
        <option value="false" selected>False</option>
    </select>
    <br><br>

    <label for="startingindex">Staring Point:</label>
    <small> From which URL you would start with? </small>
    <input type="number" id="startingindex" name="startingindex" min="1" max="<%= links.length %>" value="1">
    <br><br>

    <label for="links">Links:</label>
    <small>Number of link limit is 2 to 200. Current number of links: <%= links.length %></small>
    <br>
    <small>To remove link - just replace any existing link with the link you want to be removed. More about this in FAQ
        section. </small>

    <div id="links-container">

        <% for (var i=0; i < links.length; i++) { %>
            <!-- <label for="link<%= i %>">Link <%= i+1 %>:</label> -->
            <input type="url" name="linksList" id="link<%= i %>" required value="<%= links[i] %>"
                maxlength="<%=  maxUrlLength %>" style="min-width: 95%  ;">
            <br>
            <% } %>
    </div>

    <button type="button" id="add-link">Add Link</button>
    <button type="button" id="remove-link">Remove Blank Fields</button>
    <br><br>

    <details id="bulk-import-section">
        <summary style="cursor:pointer; font-weight:bold;">&#128230; Bulk Import URLs</summary>
        <small>Paste a JSON array of URLs. e.g. <code>["https://example.com/1.jpg", "https://example.com/2.jpg"]</code></small>
        <br>
        <small>Tip: Ask ChatGPT to generate a list of URLs in JSON array format, then paste it here.</small>
        <br><br>
        <textarea id="bulk-urls" rows="6" style="min-width:95%; font-family:monospace;" placeholder='["https://example.com/img1.jpg", "https://example.com/img2.jpg"]'></textarea>
        <br>
        <button type="button" id="bulk-import-btn">Import URLs</button>
        <button type="button" id="bulk-replace-btn">Replace All URLs</button>
        <small id="bulk-import-status" style="margin-left:8px;"></small>
    </details>
    <br>

    <button style="color: green" type="submit">Update</button>
</form>

<script>
    const addLinkButton = document.getElementById('add-link');
    const linksContainer = document.getElementById('links-container');
    const periodicityElement = document.getElementById('periodicity');
    const randomElement = document.getElementById('randomness');
    const ttlElement = document.getElementById('ttl');
    const forcingPeriodicity = function () {
        if (ttlElement.value >= 3600) {
            periodicityElement.disabled = false;
            // periodicityElement.value = 'true';
        } else {
            periodicityElement.disabled = true;
            periodicityElement.value = 'false';
        }
    }

    addLinkButton.addEventListener('click', () => {
        const input = document.createElement('input');
        input.type = 'url';
        input.name = 'linksList';
        input.id = 'link' + linksContainer.getElementsByTagName('input').length;
        input.maxLength = "<%=  maxUrlLength %>"
        input.style.width = '100%'
        input.required = true;
        linksContainer.appendChild(input);
        const breakElement = document.createElement('br');
        linksContainer.appendChild(breakElement)
    });


    // based on ttl value, select the correct option
    const ttl = "<%= ttl  %>";
    const options = ttlElement.getElementsByTagName('option');
    for (var i = 0; i < options.length; i++) {
        if (options[i].value == ttl) {
            options[i].selected = true;
        }
    }

    // based on randomness, select the correct option
    const random = "<%= random  %>";
    const options2 = randomElement.getElementsByTagName('option');
    for (var i = 0; i < options2.length; i++) {
        if (options2[i].value == random) {
            options2[i].selected = true;
        }
    }

    const periodicity = "<%= periodicity  %>";
    const options3 = periodicityElement.getElementsByTagName('option');
    for (var i = 0; i < options3.length; i++) {
        if (options3[i].value == periodicity) {
            options3[i].selected = true;
        }
    }
    forcingPeriodicity();

    // removing blank fields
    const removeLinkButton = document.getElementById('remove-link');
    removeLinkButton.addEventListener('click', () => {
        const inputs = linksContainer.getElementsByTagName('input');
        for (var i = inputs.length - 1; i >= 0; i--) {
            if (inputs[i].value == '') {
                inputs[i].remove();
                linksContainer.getElementsByTagName('br')[i].remove();
            }
        }
    })



    ttlElement.addEventListener('change', forcingPeriodicity);
    randomElement.addEventListener('change', forcingPeriodicity);

    // Bulk import logic
    const maxUrlLength = parseInt("<%= maxUrlLength %>");
    const maxLinks = 200;
    const bulkImportBtn = document.getElementById('bulk-import-btn');
    const bulkReplaceBtn = document.getElementById('bulk-replace-btn');
    const bulkUrlsTextarea = document.getElementById('bulk-urls');
    const bulkStatus = document.getElementById('bulk-import-status');

    function parseBulkUrls() {
        const raw = bulkUrlsTextarea.value.trim();
        if (!raw) { bulkStatus.textContent = '⚠ Paste a JSON array first.'; return null; }
        let urls;
        try {
            urls = JSON.parse(raw);
        } catch (e) {
            bulkStatus.textContent = '❌ Invalid JSON. Make sure it is a valid JSON array.';
            return null;
        }
        if (!Array.isArray(urls)) { bulkStatus.textContent = '❌ Must be a JSON array.'; return null; }
        // Filter and validate
        const valid = [];
        const skipped = [];
        urls.forEach(function(u, i) {
            if (typeof u !== 'string') { skipped.push('#' + (i+1) + ' (not a string)'); return; }
            u = u.trim();
            if (!u) { skipped.push('#' + (i+1) + ' (empty)'); return; }
            if (u.length > maxUrlLength) { skipped.push('#' + (i+1) + ' (too long)'); return; }
            try { new URL(u); } catch(e) { skipped.push('#' + (i+1) + ' (invalid URL)'); return; }
            valid.push(u);
        });
        if (valid.length === 0) { bulkStatus.textContent = '❌ No valid URLs found.'; return null; }
        return { valid: valid, skipped: skipped };
    }

    function addUrlField(url) {
        const input = document.createElement('input');
        input.type = 'url';
        input.name = 'linksList';
        input.id = 'link' + linksContainer.getElementsByTagName('input').length;
        input.maxLength = maxUrlLength;
        input.style.width = '100%';
        input.required = true;
        input.value = url;
        linksContainer.appendChild(input);
        linksContainer.appendChild(document.createElement('br'));
    }

    bulkImportBtn.addEventListener('click', function() {
        const result = parseBulkUrls();
        if (!result) return;
        const currentCount = linksContainer.getElementsByTagName('input').length;
        const canAdd = maxLinks - currentCount;
        if (canAdd <= 0) { bulkStatus.textContent = '❌ Already at ' + maxLinks + ' link limit.'; return; }
        const toAdd = result.valid.slice(0, canAdd);
        toAdd.forEach(function(url) { addUrlField(url); });
        let msg = '✅ Added ' + toAdd.length + ' URL(s).';
        if (toAdd.length < result.valid.length) msg += ' ' + (result.valid.length - toAdd.length) + ' skipped (limit).';
        if (result.skipped.length) msg += ' Skipped: ' + result.skipped.join(', ');
        bulkStatus.textContent = msg;
        bulkUrlsTextarea.value = '';
    });

    bulkReplaceBtn.addEventListener('click', function() {
        const result = parseBulkUrls();
        if (!result) return;
        if (!confirm('This will replace ALL existing URLs. Continue?')) return;
        // Clear existing links
        linksContainer.innerHTML = '';
        const toAdd = result.valid.slice(0, maxLinks);
        toAdd.forEach(function(url) { addUrlField(url); });
        let msg = '✅ Replaced with ' + toAdd.length + ' URL(s).';
        if (result.skipped.length) msg += ' Skipped: ' + result.skipped.join(', ');
        bulkStatus.textContent = msg;
        bulkUrlsTextarea.value = '';
    });

</script>